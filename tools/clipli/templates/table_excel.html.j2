{#
  table_excel.html.j2 — Excel-native table template.

  Generates HTML matching Excel 15/16's own clipboard format so that
  pasting into Excel preserves backgrounds, borders, colors, fonts,
  number formatting, hyperlinks, and word wrapping.

  Cell style.number_format values:
    "currency"      →  $#,##0 with red negatives
    "accounting"    →  Accounting format (parentheses negatives, dash for zero)
    "percent"       →  Percent (Excel treats value as fractional)
    "percent_int"   →  0% (integer percentage)
    "percent_1dp"   →  0.0% (one decimal percentage)
    "integer"       →  #,##0 (comma-grouped integer)
    "standard"      →  Standard (like General with more decimals)
    "text"          →  @ (force text, prevent number auto-detection)
    "datetime_iso"  →  yyyy-mm-dd hh:mm (ISO datetime)
    (omit)          →  General (default)

  Cell style fields:
    .bold          bool     — bold text (font-weight:700)
    .italic        bool     — italic text
    .fg_color      string   — text color hex, e.g. "#2E7D32"
    .bg_color      string   — background color hex (adds mso-pattern:black none)
    .alignment     string   — "left", "center", "right"
    .number_format string   — see above
    .url           string   — hyperlink URL (renders <a href> with styled span)
    .wrap          bool     — enable word wrapping (white-space:normal)

  Table style object:
    .header_bg       header background hex (default: '#4472C4')
    .header_fg       header text color hex (default: '#FFFFFF')
    .total_bg        total row background (default: '#F2F2F2')
    .default_font    font family (default: 'Calibri')
    .default_font_size  font size in pt (default: '11')

  Notes:
    - Does NOT extend _base.html.j2 — standalone HTML with Office namespaces
    - Does NOT support colspan/merged cells — use clipli write --type html
    - Empty cells render as &nbsp; per Excel convention
    - Font charset auto-detected: Aptos family → 1, others → 0
    - bg_color works on ANY cell (not just total row)
    - Last row with bg_color gets thick bottom border (total row treatment)
    - See templates/table_excel.html.md for the full reference document
#}
{%- set s = style | default(value={}) -%}
{%- set hdr_bg = s.header_bg | default('#4472C4') -%}
{%- set hdr_fg = s.header_fg | default('#FFFFFF') -%}
{%- set total_bg = s.total_bg | default('#F2F2F2') -%}
{%- set fnt = s.default_font | default(default_font | default('Calibri')) -%}
{%- set fsz = s.default_font_size | default(default_font_size | default('11')) -%}
{%- if "Aptos" in fnt -%}
  {%- set charset = "1" -%}
{%- else -%}
  {%- set charset = "0" -%}
{%- endif -%}
{#- Macro: inline style for a data cell -#}
{%- macro cell_style(cell) -%}
border-top:none;
{%- if cell.style.bold %}font-weight:700;{% endif %}
{%- if cell.style.fg_color %}color:{{cell.style.fg_color}};{% endif %}
{%- if cell.style.bg_color %}background:{{cell.style.bg_color}};mso-pattern:black none;{% endif %}
{%- if cell.style.alignment %}text-align:{{cell.style.alignment}};{% endif %}
{%- if cell.style.wrap %}white-space:normal;{% endif %}
{%- if cell.style.number_format == "currency" %}mso-number-format:"\0022$\0022\#\,\#\#0_\)\;\[Red\]\\\(\0022$\0022\#\,\#\#0\\\)";
{%- elif cell.style.number_format == "accounting" %}mso-number-format:"_\(* \#\,\#\#0_\)\;_\(* \\\(\#\,\#\#0\\\)\;_\(* \0022-\0022??_\)\;_\(\@_\)";
{%- elif cell.style.number_format == "percent" %}mso-number-format:Percent;
{%- elif cell.style.number_format == "percent_int" %}mso-number-format:0%;
{%- elif cell.style.number_format == "percent_1dp" %}mso-number-format:"0\.0%";
{%- elif cell.style.number_format == "integer" %}mso-number-format:"\#\,\#\#0";
{%- elif cell.style.number_format == "standard" %}mso-number-format:Standard;
{%- elif cell.style.number_format == "text" %}mso-number-format:"\@";
{%- elif cell.style.number_format == "datetime_iso" %}mso-number-format:"yyyy\\-mm\\-dd\\ hh\:mm";
{%- endif %}
{%- endmacro -%}
{#- Macro: render cell value with optional hyperlink, using &nbsp; for empty -#}
{%- macro cell_value(cell) -%}
{%- if cell.style.url and cell.value %}<a href="{{cell.style.url}}"><span style='color:{{cell.style.fg_color | default("black")}};font-size:{{fsz}}.0pt;text-decoration:none'>{{cell.value}}</span></a>
{%- elif cell.value %}{{cell.value}}
{%- else %}&nbsp;
{%- endif %}
{%- endmacro -%}
<html xmlns:v="urn:schemas-microsoft-com:vml"
xmlns:o="urn:schemas-microsoft-com:office:office"
xmlns:x="urn:schemas-microsoft-com:office:excel"
xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta http-equiv=Content-Type content="text/html; charset=utf-8">
<meta name=ProgId content=Excel.Sheet>
<meta name=Generator content="clipli">
<style>
<!--table
	{mso-displayed-decimal-separator:"\.";
	mso-displayed-thousand-separator:"\,";}
@page
	{margin:.75in .7in .75in .7in;
	mso-header-margin:.3in;
	mso-footer-margin:.3in;}
tr
	{mso-height-source:auto;}
col
	{mso-width-source:auto;}
br
	{mso-data-placement:same-cell;}
td
	{padding-top:1px;
	padding-right:1px;
	padding-left:1px;
	mso-ignore:padding;
	color:black;
	font-size:{{fsz}}.0pt;
	font-weight:400;
	font-style:normal;
	text-decoration:none;
	font-family:"{{fnt}}", sans-serif;
	mso-font-charset:{{charset}};
	mso-number-format:General;
	text-align:general;
	vertical-align:bottom;
	border:none;
	mso-background-source:auto;
	mso-pattern:auto;
	mso-protection:locked visible;
	white-space:nowrap;
	mso-rotate:0;}
.hdr_l
	{color:{{hdr_fg}};
	font-weight:700;
	text-align:center;
	vertical-align:middle;
	border-top:1.0pt solid windowtext;
	border-right:none;
	border-bottom:.5pt solid windowtext;
	border-left:1.0pt solid windowtext;
	background:{{hdr_bg}};
	mso-pattern:black none;}
.hdr_m
	{color:{{hdr_fg}};
	font-weight:700;
	text-align:center;
	vertical-align:middle;
	border-top:1.0pt solid windowtext;
	border-right:none;
	border-bottom:.5pt solid windowtext;
	border-left:none;
	background:{{hdr_bg}};
	mso-pattern:black none;}
.hdr_r
	{color:{{hdr_fg}};
	font-weight:700;
	text-align:center;
	vertical-align:middle;
	border-top:1.0pt solid windowtext;
	border-right:1.0pt solid windowtext;
	border-bottom:.5pt solid windowtext;
	border-left:none;
	background:{{hdr_bg}};
	mso-pattern:black none;}
.cl
	{border-top:none;
	border-right:none;
	border-bottom:.5pt solid windowtext;
	border-left:1.0pt solid windowtext;}
.cm
	{border-top:none;
	border-right:none;
	border-bottom:.5pt solid windowtext;
	border-left:none;}
.cr
	{border-top:none;
	border-right:1.0pt solid windowtext;
	border-bottom:.5pt solid windowtext;
	border-left:none;}
.tl
	{border-top:none;
	border-right:none;
	border-bottom:1.0pt solid windowtext;
	border-left:1.0pt solid windowtext;
	background:{{total_bg}};
	mso-pattern:black none;}
.tm
	{border-top:none;
	border-right:none;
	border-bottom:1.0pt solid windowtext;
	border-left:none;
	background:{{total_bg}};
	mso-pattern:black none;}
.tr
	{border-top:none;
	border-right:1.0pt solid windowtext;
	border-bottom:1.0pt solid windowtext;
	border-left:none;
	background:{{total_bg}};
	mso-pattern:black none;}
-->
</style>
</head>
<body>
<table border=0 cellpadding=0 cellspacing=0 style='border-collapse:collapse'>
<!--StartFragment-->
{%- if headers %}
 <tr height=21 style='height:16.0pt'>
{%- for cell in headers %}
{%- if loop.first %}
  <td height=21 class=hdr_l{% if cell.style.alignment %} align={{cell.style.alignment}} style='text-align:{{cell.style.alignment}}'{% endif %}{% if cell.style.wrap %} style='white-space:normal'{% endif %}>{{cell.value}}</td>
{%- elif loop.last %}
  <td class=hdr_r{% if cell.style.alignment %} align={{cell.style.alignment}} style='text-align:{{cell.style.alignment}}'{% endif %}{% if cell.style.wrap %} style='white-space:normal'{% endif %}>{{cell.value}}</td>
{%- else %}
  <td class=hdr_m{% if cell.style.alignment %} align={{cell.style.alignment}} style='text-align:{{cell.style.alignment}}'{% endif %}{% if cell.style.wrap %} style='white-space:normal'{% endif %}>{{cell.value}}</td>
{%- endif %}
{%- endfor %}
 </tr>
{%- endif %}
{%- for row in rows %}
{%- set is_last_row = loop.last %}
 <tr height=21 style='height:16.0pt'>
{%- for cell in row %}
{%- if is_last_row and cell.style.bg_color %}
{%- if loop.first %}
  <td class=tl style='{{cell_style(cell)}}'{% if cell.style.alignment %} align={{cell.style.alignment}}{% endif %}>{{cell_value(cell)}}</td>
{%- elif loop.last %}
  <td class=tr style='{{cell_style(cell)}}'{% if cell.style.alignment %} align={{cell.style.alignment}}{% endif %}>{{cell_value(cell)}}</td>
{%- else %}
  <td class=tm style='{{cell_style(cell)}}'{% if cell.style.alignment %} align={{cell.style.alignment}}{% endif %}>{{cell_value(cell)}}</td>
{%- endif %}
{%- else %}
{%- if loop.first %}
  <td class=cl style='{{cell_style(cell)}}'{% if cell.style.alignment %} align={{cell.style.alignment}}{% endif %}>{{cell_value(cell)}}</td>
{%- elif loop.last %}
  <td class=cr style='{{cell_style(cell)}}'{% if cell.style.alignment %} align={{cell.style.alignment}}{% endif %}>{{cell_value(cell)}}</td>
{%- else %}
  <td class=cm style='{{cell_style(cell)}}'{% if cell.style.alignment %} align={{cell.style.alignment}}{% endif %}>{{cell_value(cell)}}</td>
{%- endif %}
{%- endif %}
{%- endfor %}
 </tr>
{%- endfor %}
<!--EndFragment-->
</table>
</body>
</html>
